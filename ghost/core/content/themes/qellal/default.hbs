<!DOCTYPE html>
<html lang="{{@site.locale}}" class="{{#match @custom.color_scheme "Dark"}}scheme-dark{{/match}}{{#match @custom.color_scheme "Auto"}}scheme-auto{{/match}}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="HandheldFriendly" content="True">
    <meta name="theme-color" content="#17140D">

    <title>{{meta_title}}</title>

    <link rel="preload" href="{{asset "fonts/hanken-grotesk.woff2"}}" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="{{asset "fonts/space-grotesk.woff2"}}" as="font" type="font/woff2" crossorigin>
    <link rel="stylesheet" type="text/css" href="{{asset "built/screen.css"}}">

    {{!-- Apply a visitor's saved light/dark choice before first paint (no flash). --}}
    <script>(function(){try{var t=localStorage.getItem('qellal-theme');if(t==='dark'||t==='light'){document.documentElement.setAttribute('data-theme',t);}}catch(e){}})();</script>

    {{#if @member}}<script>window.QELLAL_MEMBER = { uuid: "{{@member.uuid}}", email: "{{@member.email}}" };</script>{{/if}}
    {{ghost_head}}
</head>
<body class="{{body_class}}">
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header no-print">
        <div class="wrap site-header-inner">
            <a class="brand" href="{{@site.url}}">
                <span class="brand-mark" aria-hidden="true"></span>
                <span class="brand-name">{{@site.title}}</span>
            </a>
            <div class="nav-cluster">
                <nav class="site-nav" id="site-nav" aria-label="Main">
                    {{navigation}}
                </nav>
                <div class="nav-actions">
                    <button class="icon-btn" type="button" data-tender-search aria-label="Search tenders">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.3-4.3"></path></svg>
                    </button>
                    <button class="icon-btn" type="button" data-theme-toggle aria-label="Switch between light and dark">
                        <svg class="theme-ic-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path></svg>
                        <svg class="theme-ic-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2m0 16v2M2 12h2m16 0h2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"></path></svg>
                    </button>
                    <button class="icon-btn saved-btn" type="button" data-saved-toggle aria-label="Saved tenders" hidden>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 3h12a1 1 0 0 1 1 1v17l-7-4-7 4V4a1 1 0 0 1 1-1Z"></path></svg>
                        <span class="saved-count" data-saved-count hidden>0</span>
                    </button>
                    {{#if @site.members_enabled}}
                        {{#if @member}}
                        <a class="btn btn-secondary btn-sm" href="{{@site.url}}/my-alerts/">Alerts</a>
                        <a class="btn btn-primary btn-sm" href="#/portal/account" data-portal="account">Account</a>
                        {{else}}
                        <a class="btn btn-primary btn-sm" href="#/portal/signin" data-portal="signin">Sign in</a>
                        {{/if}}
                    {{/if}}
                    <button class="icon-btn nav-toggle" type="button" aria-label="Menu" aria-expanded="false" aria-controls="site-nav">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18"></path></svg>
                    </button>
                </div>
            </div>
        </div>
    </header>

    <div id="main" class="site-main" tabindex="-1">
        {{{body}}}
    </div>

    <footer class="site-footer no-print">
        <div class="wrap">
            <div class="footer-grid">
                <div class="footer-brand">
                    <div class="brand brand--dark">
                        <span class="brand-mark brand-mark--dark" aria-hidden="true"></span>
                        <span class="brand-name">{{@site.title}}</span>
                    </div>
                    <p class="footer-blurb">{{#if @site.description}}{{@site.description}}{{else}}Every Ethiopian tender notice in one place, with email alerts so you never miss a deadline.{{/if}}</p>
                </div>
                <div class="footer-col">
                    <h2 class="footer-heading">Product</h2>
                    {{#if @site.secondary_navigation}}
                        {{navigation type="secondary"}}
                    {{else}}
                    <ul>
                        <li><a href="{{@site.url}}">Browse tenders</a></li>
                        {{#if @site.members_enabled}}
                        <li><a href="#/portal/signup" data-portal="signup">Create free account</a></li>
                        <li><a href="#/portal/signin" data-portal="signin">Sign in</a></li>
                        {{/if}}
                    </ul>
                    {{/if}}
                </div>
                <div class="footer-col">
                    <h2 class="footer-heading">Sources</h2>
                    <p class="footer-blurb">Aggregated from public Ethiopian tender notices. Every listing links to its original source.</p>
                    <ul><li><a href="{{@site.url}}/rss/">Follow all tenders by RSS →</a></li></ul>
                </div>
            </div>
            <div class="footer-base">
                <span>&copy; {{date format="YYYY"}} {{@site.title}} &middot; Ethiopian tender alerts</span>
                <span>Built for procurement teams who never miss a deadline.</span>
            </div>
        </div>
    </footer>

    {{!-- Saved-tenders drawer, filled client-side from localStorage. --}}
    <div class="drawer-overlay no-print" data-saved-overlay hidden></div>
    <aside class="saved-drawer no-print" data-saved-drawer aria-label="Saved tenders" aria-hidden="true">
        <div class="saved-drawer-head">
            <h2>Saved tenders <span class="saved-count-inline" data-saved-count-inline></span></h2>
            <button class="icon-btn" type="button" data-saved-close aria-label="Close saved tenders">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"></path></svg>
            </button>
        </div>
        <div class="saved-drawer-body" data-saved-list></div>
    </aside>

    {{> search-modal}}

    {{!-- Meilisearch config for the tender search (search-only key is safe to expose). --}}
    <script>
        window.QELLAL_SEARCH = {
            host: "{{@custom.meili_host}}",
            index: "{{@custom.meili_index}}",
            key: "{{@custom.meili_search_key}}"
        };
    </script>
    <script src="{{asset "built/categories.js"}}"></script>
    <script src="{{asset "js/tender.js"}}"></script>
    {{ghost_foot}}
</body>
</html>
