{{!-- Client-side list controls. Hidden until tender.js confirms the page has
      deadline-bearing cards, so it never shows a dead control with JS off.
      Filters act on the current page (Ghost paginates server-side). --}}
<div class="list-toolbar" data-list-toolbar hidden>
    <div class="seg" role="group" aria-label="Sort tenders">
        <button type="button" data-list-view="grouped" aria-pressed="true">Closing soon</button>
        <button type="button" data-list-view="newest" aria-pressed="false">Newest</button>
    </div>
    <div class="seg" role="group" aria-label="Layout density">
        <button type="button" data-list-density="cards" aria-pressed="true">Cards</button>
        <button type="button" data-list-density="compact" aria-pressed="false">Compact</button>
    </div>
    <label class="toolbar-field" hidden data-cat-field>
        <span class="visually-hidden">Category</span>
        <select data-cat-filter aria-label="Filter by category">
            <option value="">All categories</option>
        </select>
    </label>
    <input class="toolbar-search" type="search" data-text-filter placeholder="Filter this page…" aria-label="Filter tenders on this page">
    <label class="toolbar-check">
        <input type="checkbox" data-hide-closed> Hide closed
    </label>
</div>
