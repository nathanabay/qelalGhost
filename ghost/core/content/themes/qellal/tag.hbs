{{!< default}}

{{!-- Tender listing for a tag (e.g. /tag/2merkato/ = all tenders, or a
      category tag). The posts loop and {{pagination}} live at the root
      (paginated) context; {{#tag}} is used only for the header. --}}

{{#tag}}
<header class="archive-hero">
    {{#if feature_image}}<img class="archive-hero-img" src="{{img_url feature_image size="l"}}" alt="{{name}}" loading="lazy">{{/if}}
    <h1>{{name}}</h1>
    <p><span class="count">{{plural ../pagination.total empty='No tenders' singular='% tender' plural='% tenders'}}</span>{{#if description}} · {{description}}{{/if}}</p>
</header>
{{/tag}}

<section class="tender-list" data-tender-page>
    <div class="tender-list-head">
        <div></div>
        <a class="link-more" href="{{@site.url}}">Home</a>
    </div>

    {{> list-toolbar}}

    {{#if posts}}
    <ul class="tender-cards" data-tender-list>
        {{#foreach posts}}
            <li>{{> tender-card}}</li>
        {{/foreach}}
    </ul>
    {{else}}
    <p style="color:var(--muted)">No tenders here yet.</p>
    {{/if}}
</section>

{{pagination}}

{{> subscribe}}
