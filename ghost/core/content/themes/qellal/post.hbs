{{!< default}}

{{#post}}
<main class="detail" data-tender-detail data-excerpt="{{excerpt}}">
    <nav class="breadcrumb no-print" aria-label="Breadcrumb">
        <a href="{{@site.url}}">Home</a> <span aria-hidden="true">/</span>
        <a href="{{@site.url}}/tenders/">Tenders</a>
    </nav>

    <div class="detail-grid">
        <div class="detail-main">
            <h1>{{title}}</h1>
            {{#has tag="featured,proforma"}}
            <div class="detail-flags">
                {{#has tag="featured"}}<span class="badge featured-badge">★ Featured</span>{{/has}}
                {{#has tag="proforma"}}<span class="badge">Proforma</span>{{/has}}
            </div>
            {{/has}}

            <section class="card-section">
                <h2>Description</h2>
                <div class="card-body">
                    <div class="gh-content" data-tender-content>
                        {{content}}
                    </div>
                </div>
            </section>

            <section class="card-section documents-card" data-documents-slot hidden>
                <h2>Documents</h2>
                <div class="card-body" data-documents-body></div>
            </section>

            {{#if tags}}
            <section class="detail-categories">
                <h2 class="detail-categories-heading">Categories</h2>
                <div class="detail-chips">
                    {{#foreach tags}}<a class="chip" data-tag="{{slug}}" href="{{url}}">{{name}}</a>{{/foreach}}
                </div>
            </section>
            {{/if}}

            {{#if canonical_url}}
            <section class="source-card">
                <h2>Source</h2>
                <div class="source-card-row">
                    <div>
                        <p class="em" style="font-weight:600;color:var(--ink)">{{#if @custom.source_name}}{{@custom.source_name}}{{else}}2merkato{{/if}}</p>
                        <p style="margin:.25rem 0 0;font-size:.75rem;color:var(--muted)">Always verify against the original notice before bidding.</p>
                    </div>
                    <a class="btn btn-secondary btn-sm" href="{{canonical_url}}" target="_blank" rel="noopener noreferrer">View original ↗</a>
                </div>
            </section>
            {{/if}}

            <a class="back-link no-print" href="{{@site.url}}/tenders/">← Back to all tenders</a>
        </div>

        <aside class="detail-aside">
            <div class="deadline-card" data-deadline-card data-title="{{title}}">
                <p class="deadline-kicker" data-deadline-kicker>Deadline</p>
                <div class="deadline-count is-closed" data-deadline-count>—</div>
                <p class="deadline-sub" data-deadline-sub>Published {{date format="D MMM YYYY"}}</p>
                <dl class="deadline-facts" data-deadline-facts hidden></dl>
            </div>

            <div class="detail-actions no-print" data-detail-actions hidden>
                <button class="btn btn-primary btn-sm" type="button" data-save-tender aria-pressed="false">☆ Save tender</button>
                <a class="btn btn-secondary btn-sm" data-add-calendar download="tender.ics" href="#">＋ Add deadline to calendar</a>
                <button class="btn btn-secondary btn-sm" type="button" data-share>⧉ Share this tender</button>
                <button class="btn btn-secondary btn-sm" type="button" data-copy-facts>⧉ Copy details</button>
                <button class="btn btn-secondary btn-sm" type="button" data-print>⎙ Print / save as PDF</button>
            </div>
            <p class="share-toast no-print" data-share-toast aria-live="polite"></p>
        </aside>
    </div>

    {{#if primary_tag}}
    {{#get "posts" filter="tag:{{primary_tag.slug}}+id:-{{id}}" limit="3" order="published_at desc"}}
        {{#if posts}}
        <section class="related no-print">
            <h2>More tenders like this</h2>
            <ul class="tender-cards">
                {{#foreach posts}}
                    <li>{{> tender-card}}</li>
                {{/foreach}}
            </ul>
        </section>
        {{/if}}
    {{/get}}
    {{/if}}
</main>
{{/post}}
