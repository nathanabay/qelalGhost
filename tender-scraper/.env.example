# Ghost tender scraper — environment. Copy to `.env` (gitignored) and fill in.

# Ghost Admin API (Settings → Integrations → Add custom integration).
# The key is shown as "<id>:<hex-secret>".
GHOST_ADMIN_API_URL=http://localhost:2368
GHOST_ADMIN_API_KEY=

# 2merkato subscriber login (optional). Without it, most closing dates are
# hidden and only the ~20% of tenders with public deadlines are scraped.
MERKATO_USERNAME=
MERKATO_PASSWORD=

# Scheduler interval in minutes (used by `npm run schedule`). Default 360 (6h).
SCRAPE_INTERVAL_MINUTES=360

# Listing pages to crawl per run (default 500; the crawl auto-stops at the end
# of the open-tender set well before this).
SCRAPE_PAGES=500

# ── Notifier service (src/notify) — BOOTSTRAP ONLY ──────────────────────────
# Everything operator-facing (bot token, SMTP, policy) is entered on the Ghost
# "Alerts" admin page and stored in the DB — NOT here. These only let the
# service boot and reach its store / Ghost / Meilisearch.
NOTIFY_PORT=3839
NOTIFY_DB_HOST=127.0.0.1
NOTIFY_DB_PORT=3306
NOTIFY_DB_USER=root
NOTIFY_DB_PASSWORD=
NOTIFY_DB_NAME=tender_notify
GHOST_URL=https://tenders.qelal.et
# Meili read access for matching (search key preferred; master key also works).
MEILI_HOST=
MEILI_SEARCH_KEY=
MEILI_INDEX=ghost_tenders
